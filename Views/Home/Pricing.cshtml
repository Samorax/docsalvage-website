    <!-- HOW PROCESSING WORKS -->
    <section style="padding:84px 0;background:#F6F3EC;border-top:1px solid #ECE5D8;border-bottom:1px solid #ECE5D8">
      <div style="max-width:1100px;margin:0 auto;padding:0 32px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start">
