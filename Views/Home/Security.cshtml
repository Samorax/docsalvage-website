          <span style="font-family:'IBM Plex Mono',monospace;font-size:13px;color:#9DB8C4;border:1px solid rgba(255,255,255,.14);border-radius:7px;padding:8px 14px">TLS 1.2</span>
          <span style="font-family:'IBM Plex Mono',monospace;font-size:13px;color:#9DB8C4;border:1px solid rgba(255,255,255,.14);border-radius:7px;padding:8px 14px">Microsoft Entra ID</span>
        </div>
