<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>@ViewData["Title"]</title>
<meta name="description" content="@ViewData["Description"]" />
<meta name="keywords" content="document management software, document management system, DMS, AI document management, cloud document storage, scan and store documents, OCR invoice scanning, invoice processing software, invoice data extraction, automated bookkeeping software, accounts payable automation, payables and receivables, bank reconciliation software, audit trail software, AI document search, semantic document search, search documents by content, Microsoft 365 document management, SharePoint alternative, Azure document storage, Microsoft Entra SSO, pay-as-you-go document management, small business document management, paperless office software, enterprise content management" />
<meta name="author" content="BYBWE Limited" />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="theme-color" content="#06303F" />
<link rel="canonical" href="@ViewData["Canonical"]" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Doc-Salvage" />
<meta property="og:title" content="@ViewData["Title"]" />
<meta property="og:description" content="@ViewData["Description"]" />
<meta property="og:url" content="@ViewData["Canonical"]" />
<meta property="og:image" content="https://docsalvage.cloud/assets/og-image.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Doc-Salvage — AI document management for the workplace" />
<meta property="og:locale" content="en_US" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="@ViewData["Title"]" />
<meta name="twitter:description" content="@ViewData["Description"]" />
<meta name="twitter:image" content="https://docsalvage.cloud/assets/og-image.png" />
<meta name="twitter:image:alt" content="Doc-Salvage — AI document management for the workplace" />
<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@graph": [
    {
      "@@type": "Organization",
      "@@id": "https://docsalvage.cloud/#organization",
      "name": "BYBWE Limited",
      "url": "https://bybwe.com",
      "logo": "https://docsalvage.cloud/assets/favicon.png",
      "email": "hello@@bybwe.com",
      "brand": "Doc-Salvage",
      "description": "BYBWE Limited is the maker of Doc-Salvage, an AI-powered document management system for the workplace, built on Microsoft Azure and 365."
    },
    {
      "@@type": "WebSite",
      "@@id": "https://docsalvage.cloud/#website",
      "url": "https://docsalvage.cloud/",
      "name": "Doc-Salvage",
      "publisher": { "@@id": "https://docsalvage.cloud/#organization" },
      "inLanguage": "en-US"
    },
    {
      "@@type": "SoftwareApplication",
      "name": "Doc-Salvage",
      "operatingSystem": "Windows 10, Windows 11",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "Document Management System",
      "url": "https://docsalvage.cloud/",
      "image": "https://docsalvage.cloud/assets/og-image.png",
      "description": "AI document management for the workplace — store documents on Azure, search by meaning, process invoices into your accounting system, and collaborate through Microsoft 365.",
      "publisher": { "@@id": "https://docsalvage.cloud/#organization" },
      "author": { "@@id": "https://docsalvage.cloud/#organization" },
      "featureList": [
        "Store documents on Microsoft Azure",
        "AI semantic search across all documents",
        "Process invoices, payables and receivables into accounting systems",
        "Bank reconciliation, audit trails and versioning",
        "Collaborate through Microsoft 365 permissions",
        "Microsoft Entra single sign-on"
      ],
      "offers": [
        {
          "@@type": "Offer",
          "name": "Storage",
          "price": "22.00",
          "priceCurrency": "USD",
          "description": "Per terabyte of documents stored per month",
          "category": "pay-as-you-go"
        },
        {
          "@@type": "Offer",
          "name": "Document processing",
          "price": "1.00",
          "priceCurrency": "USD",
          "description": "Per invoice document processed",
          "category": "pay-as-you-go"
        }
      ]
    },
    {
      "@@type": "FAQPage",
      "@@id": "https://docsalvage.cloud/#faq",
      "mainEntity": [
        {
          "@@type": "Question",
          "name": "What is Doc-Salvage?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Doc-Salvage is an AI document management system for the workplace. It lets you store documents on Microsoft Azure, search them by meaning, process invoices into your accounting system, and collaborate through Microsoft 365 — all from one platform with pay-as-you-go pricing."
          }
        },
        {
          "@@type": "Question",
          "name": "How much does Doc-Salvage cost?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Pricing is pay-as-you-go with no subscription or lock-in. Storage is $22 per terabyte per month, AI search is free, and document processing is $1 per invoice document. You only pay for what you use, billed per company account."
          }
        },
        {
          "@@type": "Question",
          "name": "Does Doc-Salvage work with Microsoft 365 and SharePoint?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Yes. Doc-Salvage is built natively on Microsoft Azure and 365. Sharing, roles and access control are inherited from your Microsoft 365 directory, and users sign in with Microsoft Entra single sign-on. It is a practical alternative to SharePoint document libraries for storage, AI search and invoice processing."
          }
        },
        {
          "@@type": "Question",
          "name": "Can Doc-Salvage automatically process invoices and post to my accounting system?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Yes. Doc-Salvage uses AI to extract totals, dates, vendor and line items from invoices and receipts, posts payables and receivables into your accounting system, reconciles entries against bank statements, and keeps a complete audit trail — with no manual re-keying."
          }
        },
        {
          "@@type": "Question",
          "name": "Where are my documents stored and are they secure?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Documents are stored on Microsoft Azure inside your own cloud tenant, so your data stays in your control with the data residency you choose. Storage scales elastically from gigabytes to petabytes with automatic redundancy, and access is governed by Microsoft Entra single sign-on and your M365 permissions."
          }
        },
        {
          "@@type": "Question",
          "name": "Can I search documents by their content?",
          "acceptedAnswer": {
            "@@type": "Answer",
            "text": "Yes. Doc-Salvage AI reads the contents of every document, so you can search using natural language and find files by what they mean — across scans, PDFs and Office files — instead of remembering an exact filename or folder. Results respect your M365 permissions."
          }
        }
      ]
    }
  ]
}
</script>
<link rel="icon" type="image/png" href="/assets/favicon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@@400;500;600;700;800&family=IBM+Plex+Mono:wght@@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/site.css" />
</head>
<body>
<div style="background:#fff;min-height:100vh;overflow-x:hidden">

    @* <div style="background:#06303F;color:#C9D6EA;font-size:13.5px;text-align:center;padding:9px 24px;font-weight:500;letter-spacing:.01em">
      <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#1772A8;margin-right:9px;vertical-align:middle"></span>New: invoice processing is now generally available across all Azure regions.
    </div> *@
  
<!-- NAV -->
  <header style="position:sticky;top:0;z-index:50;background:rgba(255,255,255,.86);backdrop-filter:blur(14px);border-bottom:1px solid #ECE5D8">
    <div style="max-width:1200px;margin:0 auto;padding:0 32px;height:68px;display:flex;align-items:center;gap:40px">
      <div onclick="location.href='/'" style="display:flex;align-items:center;gap:10px;cursor:pointer;flex-shrink:0">
        <img src="/assets/mark.png" alt="Doc-Salvage" style="width:34px;height:34px;border-radius:9px;display:block;object-fit:cover;box-shadow:0 1px 2px rgba(13,26,43,.12)">
        <span style="font-weight:800;font-size:18px;letter-spacing:-.02em;color:#083A4D">Doc&#8209;Salvage</span>
      </div>
      <nav style="display:flex;align-items:center;gap:28px;font-size:14.5px;font-weight:500;flex:1">
        <span onclick="location.href='/capabilities'" style="cursor:pointer;color:#3A4A60" data-hover="color:#083A4D">Capabilities</span>
        <span onclick="location.href='/bookkeeping'" style="cursor:pointer;color:#3A4A60" data-hover="color:#083A4D">Solutions</span>
        <span onclick="location.href='/pricing'" style="cursor:pointer;color:#3A4A60" data-hover="color:#083A4D">Pricing</span>
        <span onclick="location.href='/security'" style="cursor:pointer;color:#3A4A60" data-hover="color:#083A4D">Security</span>
        <span onclick="location.href='/docs'" style="cursor:pointer;color:#3A4A60" data-hover="color:#083A4D">Docs</span>
      </nav>
      <div style="display:flex;align-items:center;gap:18px;flex-shrink:0">
        <span onclick="location.href='ms-appinstaller:?source=https://docsalvage.cloud/Doc-Salvage_x64.appinstaller'" style="cursor:pointer;background:#1772A8;color:#fff;padding:9px 17px;border-radius:8px;font-size:14px;font-weight:600;box-shadow:0 1px 2px rgba(13,26,43,.18)" data-hover="background:#125D8A">Download</span>
      </div>
    </div>
  </header>
@RenderBody()
<!-- FOOTER -->
  <footer style="background:#06303F;color:#fff;padding:64px 0 36px">
    <div style="max-width:1200px;margin:0 auto;padding:0 32px">
      <div style="display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px;padding-bottom:44px;border-bottom:1px solid rgba(255,255,255,.1)">
        <div>
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
            <img src="/assets/mark.png" alt="Doc-Salvage" style="width:34px;height:34px;border-radius:9px;display:block;object-fit:cover">
            <span style="font-weight:800;font-size:18px;letter-spacing:-.02em">Doc&#8209;Salvage</span>
          </div>
          <p style="font-size:14px;color:#8499B5;line-height:1.6;max-width:280px;margin:0">The AI document management system for the workplace — built on Azure and Microsoft 365.</p>
        </div>
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#6E83A0;margin-bottom:16px">Product</div>
          <div style="display:flex;flex-direction:column;gap:11px;font-size:14px;color:#AFC0D8">
            <span onclick="location.href='/capabilities'" style="cursor:pointer" data-hover="color:#fff">Capabilities</span>
            <span onclick="location.href='/pricing'" style="cursor:pointer" data-hover="color:#fff">Pricing</span>
            <span onclick="location.href='/security'" style="cursor:pointer" data-hover="color:#fff">Security</span>
            <span onclick="location.href='ms-appinstaller:?source=https://docsalvage.cloud/Doc-Salvage_x64.appinstaller'" style="cursor:pointer" data-hover="color:#fff">Download</span>
          </div>
        </div>
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#6E83A0;margin-bottom:16px">Solutions</div>
          <div style="display:flex;flex-direction:column;gap:11px;font-size:14px;color:#AFC0D8">
            <span onclick="location.href='/bookkeeping'" style="cursor:pointer" data-hover="color:#fff">Bookkeeping</span>
            <span onclick="location.href='/bookkeeping'" style="cursor:pointer" data-hover="color:#fff">Payables &amp; receivables</span>
            <span onclick="location.href='/bookkeeping'" style="cursor:pointer" data-hover="color:#fff">Audit &amp; compliance</span>
          </div>
        </div>
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#6E83A0;margin-bottom:16px">Resources</div>
          <div style="display:flex;flex-direction:column;gap:11px;font-size:14px;color:#AFC0D8">
            <span onclick="location.href='/docs'" style="cursor:pointer" data-hover="color:#fff">User guide</span>
            <span style="cursor:pointer" data-hover="color:#fff">Support</span>
          </div>
        </div>
      </div>
      <div style="padding-top:26px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;font-size:13px;color:#6E83A0">
        <span>&copy; @DateTime.Now.Year <a href="https://bybwe.com" target="_blank" rel="noopener" style="color:inherit;text-decoration:none" data-hover="color:#AFC0D8">BYBWE Limited</a>. Doc&#8209;Salvage is a product of <a href="https://bybwe.com" target="_blank" rel="noopener" style="color:inherit;text-decoration:none" data-hover="color:#AFC0D8">BYBWE Limited</a>.</span>
        <span style="display:flex;gap:22px">
          <span style="cursor:pointer" data-hover="color:#AFC0D8">Privacy</span>
          <span style="cursor:pointer" data-hover="color:#AFC0D8">Terms</span>
          <span style="cursor:pointer" data-hover="color:#AFC0D8">Status</span>
        </span>
      </div>
    </div>
  </footer>
</div>
<script src="/js/site.js"></script>
</body>
</html>
